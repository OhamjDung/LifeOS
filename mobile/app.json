{
  "expo": {
    "name": "LifeOS",
    "slug": "lifeos",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "lifeos",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.lifeos.app",
      "jsEngine": "hermes",
      "infoPlist": {
        "NSSpeechRecognitionUsageDescription": "LifeOS uses speech recognition to transcribe your voice braindumps.",
        "NSMicrophoneUsageDescription": "LifeOS needs microphone access to record your voice braindumps.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "LifeOS uses your location to automatically switch modes when you arrive at home, work, or the gym.",
        "NSLocationWhenInUseUsageDescription": "LifeOS uses your location to detect which mode you're in.",
        "UIBackgroundModes": [
          "location",
          "fetch"
        ],
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#111827",
        "foregroundImage": "./assets/android-icon-foreground.png"
      },
      "package": "com.lifeos.app",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "RECORD_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "LifeOS uses your location to automatically switch modes."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "d1718d90-13b5-4480-9d28-3bf478cfd19b"
      }
    },
    "owner": "tompham"
  }
}
